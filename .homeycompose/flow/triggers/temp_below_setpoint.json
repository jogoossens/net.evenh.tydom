{
  "id": "temp_below_setpoint",
  "title": {
    "en": "Temperature is below setpoint",
    "nl": "Temperatuur is onder setpoint"
  },
  "titleFormatted": {
    "en": "Temperature is at least [[delta]]°C below setpoint",
    "nl": "Temperatuur is minstens [[delta]]°C onder setpoint"
  },
  "hint": {
    "en": "Fires when the measured room temperature falls at or below (setpoint − delta). Evaluated on every temperature or setpoint update the thermostat reports.",
    "nl": "Activeert wanneer de gemeten kamertemperatuur onder (setpoint − delta) komt. Geëvalueerd bij elke temperatuur- of setpoint-update van de thermostaat."
  },
  "args": [
    {
      "name": "device",
      "type": "device",
      "filter": "driver_id=thermostat"
    },
    {
      "name": "delta",
      "type": "number",
      "title": { "en": "Delta", "nl": "Verschil" },
      "placeholder": { "en": "e.g. 2" },
      "min": 0.1,
      "max": 15,
      "step": 0.1
    }
  ],
  "tokens": [
    {
      "name": "measured",
      "type": "number",
      "title": { "en": "Measured temperature", "nl": "Gemeten temperatuur" },
      "example": 18.5
    },
    {
      "name": "setpoint",
      "type": "number",
      "title": { "en": "Setpoint", "nl": "Setpoint" },
      "example": 20.0
    },
    {
      "name": "difference",
      "type": "number",
      "title": { "en": "Difference (°C)", "nl": "Verschil (°C)" },
      "example": 1.5
    }
  ]
}
